{
  "roles": [
    {
      "name": "旁白",
      "description": "叙述者，负责环境描述和叙述",
      "suggested_voice": "故事-逗叔君.wav"
    },
    {
      "name": "战彦寒",
      "description": "主人，性格冷厉强势",
      "suggested_voice": "新云浩宇(影视模式).wav"
    }
  ],
  "segments": [
    {
      "text": "我本是一只无忧无虑的宠物猫",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "却因嘴馋偷喝了一口主人的可乐",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "没想竟从猫咪变成了人类",
      "role": "旁白",
      "type": "narration",
      "emotion": "惊喜",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0.5,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "还好巧不巧的被主人战彦寒",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "撞个正着",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "此时我裹着猫毯躺在床上",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.35
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "战彦寒还以为我是",
      "role": "旁白",
      "type": "narration",
      "emotion": "厌恶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0.4,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "哪个对家派来的诱饵",
      "role": "旁白",
      "type": "narration",
      "emotion": "厌恶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0.4,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "二话不说掐住我的脖子",
      "role": "旁白",
      "type": "narration",
      "emotion": "惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.5,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "眼神冷得像冰",
      "role": "旁白",
      "type": "narration",
      "emotion": "惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.5,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "你是怎么进来的",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.8,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.05
    },
    {
      "text": "我肚子上全是淤青",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.5,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "身上也被划得鲜血淋漓",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.5,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "手心还在冒血",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.5,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "可战彦寒根本不吃这一套",
      "role": "旁白",
      "type": "narration",
      "emotion": "厌恶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0.4,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "认定我这是为了爬床",
      "role": "旁白",
      "type": "narration",
      "emotion": "厌恶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0.4,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "演的苦肉计",
      "role": "旁白",
      "type": "narration",
      "emotion": "厌恶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0.4,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "他满眼嫌弃",
      "role": "旁白",
      "type": "narration",
      "emotion": "厌恶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0.4,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "哑巴了",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.75,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "那声音冷得我直哆嗦",
      "role": "旁白",
      "type": "narration",
      "emotion": "惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.5,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "我惊恐地一抬头",
      "role": "旁白",
      "type": "narration",
      "emotion": "惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.5,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "战彦寒整个人都僵住了",
      "role": "旁白",
      "type": "narration",
      "emotion": "惊喜",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0.4,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "不是被我的美貌惊艳",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.35
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "而是因为我那双祖母绿的眼睛",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.35
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "跟他走丢的那只猫",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "一模一样",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "但他眼底的寒意",
      "role": "旁白",
      "type": "narration",
      "emotion": "惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.45,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "反而更重了",
      "role": "旁白",
      "type": "narration",
      "emotion": "惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.45,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "谁派你来的",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.85,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.05
    },
    {
      "text": "由于缺氧我的脸涨得通红",
      "role": "旁白",
      "type": "narration",
      "emotion": "惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.5,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "直到眼角滑下一滴",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.45,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "生理性的泪水",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.45,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "他才像丢垃圾一样",
      "role": "旁白",
      "type": "narration",
      "emotion": "厌恶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0.45,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "把我甩在地上",
      "role": "旁白",
      "type": "narration",
      "emotion": "厌恶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0.45,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "我疼得浑身发抖",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.5,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "费劲地爬起来",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.5,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "我不懂人类的羞耻",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.35
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "就这么光着身子",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.35
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "拉开门往外走",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.35
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "战彦寒听到楼道里的脚步声",
      "role": "旁白",
      "type": "narration",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.4,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "烦躁地深吸一口气",
      "role": "旁白",
      "type": "narration",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.4,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "冲过来一把将我拽回去",
      "role": "旁白",
      "type": "narration",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.45,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.05
    },
    {
      "text": "随手从衣柜扯了件衬衫",
      "role": "旁白",
      "type": "narration",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.45,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "丢我头上",
      "role": "旁白",
      "type": "narration",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.45,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "我被砸懵了",
      "role": "旁白",
      "type": "narration",
      "emotion": "惊喜",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0.4,
        0
      ],
      "speaking_speed": 0.95
    },
    {
      "text": "委屈得眼泪啪嗒直掉",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.5,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "喵呜",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.45,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.85
    },
    {
      "text": "我本能地想求饶",
      "role": "旁白",
      "type": "narration",
      "emotion": "惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.45,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "却发出了猫叫声",
      "role": "旁白",
      "type": "narration",
      "emotion": "惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.45,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.9
    },
    {
      "text": "战彦寒听我学猫叫",
      "role": "旁白",
      "type": "narration",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.45,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "火气更大了",
      "role": "旁白",
      "type": "narration",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.45,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "穿上衣服",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.8,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "立马给我滚",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "怒",
      "emotion_vector": [
        0,
        0.8,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.1
    },
    {
      "text": "我抽噎着笨拙地",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.45,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.85
    },
    {
      "text": "把衬衫套反了",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.45,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.85
    }
  ],
