      "emotion_vector": [
        0,
        0,
        0,
        0.4,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒脸色一沉",
