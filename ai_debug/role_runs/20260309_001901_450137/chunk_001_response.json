      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒没理他",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "直接扒开草垛把我提溜了出来",
