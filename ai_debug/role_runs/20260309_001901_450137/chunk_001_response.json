{
  "block_id": "block_001",
  "segments": [
    {
      "text": "我本是一只无忧无虑的宠物猫",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "却因嘴馋偷喝了一口主人的可乐",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "没想竟从猫咪变成了人类",
      "role": "旁白",
      "type": "narration",
      "emotion": "略带惊讶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0.3,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "还好巧不巧的被主人战彦寒撞个正着",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "此时我裹着猫毯躺在床上",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒还以为我是哪个对家派来的诱饵",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "二话不说掐住我的脖子",
      "role": "旁白",
      "type": "narration",
      "emotion": "略带紧张",
      "emotion_vector": [
        0,
        0,
        0,
        0.3,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "眼神冷得像冰",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "你是怎么进来的",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "愤怒",
      "emotion_vector": [
        0,
        0.8,
        0,
        0,
        0,
        0,
        0,
        0.2
      ],
      "speaking_speed": 1.1,
      "voice": "新云浩宇(影视模式).wav"
    },
    {
      "text": "我肚子上全是淤青",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "身上也被划得鲜血淋漓",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "手心还在冒血",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "可战彦寒根本不吃这一套",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "认定我这是为了爬床演的苦肉计",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "他满眼嫌弃",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "哑巴了",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "愤怒",
      "emotion_vector": [
        0,
        0.9,
        0,
        0,
        0,
        0,
        0,
        0.1
      ],
      "speaking_speed": 1.2,
      "voice": "新云浩宇(影视模式).wav"
    },
    {
      "text": "那声音冷得我直哆嗦",
      "role": "旁白",
      "type": "narration",
      "emotion": "恐惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.4,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我惊恐地一抬头",
      "role": "旁白",
      "type": "narration",
      "emotion": "恐惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.4,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒整个人都僵住了",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "不是被我的美貌惊艳",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "而是因为我那双祖母绿的眼睛",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "跟他走丢的那只猫一模一样",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "但他眼底的寒意反而更重了",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "谁派你来的",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "愤怒",
      "emotion_vector": [
        0,
        0.9,
        0,
        0,
        0,
        0,
        0,
        0.1
      ],
      "speaking_speed": 1.2,
      "voice": "新云浩宇(影视模式).wav"
    },
    {
      "text": "由于缺氧我的脸涨得通红",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "直到眼角滑下一滴生理性的泪水",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "他才像丢垃圾一样把我甩在地上",
      "role": "旁白",
      "type": "narration",
      "emotion": "略带愤怒",
      "emotion_vector": [
        0,
        0.3,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我疼得浑身发抖费劲地爬起来",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.5,
        0,
        0.5
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我不懂人类的羞耻",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "就这么光着身子拉开门往外走",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒听到楼道里的脚步声",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "烦躁地深吸一口气",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "冲过来一把将我拽回去",
      "role": "旁白",
      "type": "narration",
      "emotion": "略带紧张",
      "emotion_vector": [
        0,
        0,
        0,
        0.2,
        0,
        0,
        0,
        0.8
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "随手从衣柜扯了件衬衫丢我头上",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我被砸懵了",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.3,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "委屈得眼泪啪嗒直掉",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "喵呜",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我本能地想求饶却发出了猫叫声",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒听我学猫叫火气更大了",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "穿上衣服立马给我滚",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "愤怒",
      "emotion_vector": [
        0,
        1.0,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.3,
      "voice": "新云浩宇(影视模式).wav"
    },
    {
      "text": "我抽噎着笨拙地把衬衫套反了",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "临走前",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我依依不舍地看了他一眼",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.3,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "却只见他满脸阴沉",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "外头雷雨交加",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒躺在床上翻来覆去睡不着",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "脑子里全是我临走前那个绝望的眼神",
      "role": "旁白",
      "type": "narration",
      "emotion": "低落",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.3,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "天一亮门外就传来了动静",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "四爷找到了",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "十几个保镖撑着黑伞围在他身后",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒蹲下身",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "冲着躲在草丛里的我拍手",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "西西过来",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "平静带期待",
      "emotion_vector": [
        0.2,
        0,
        0,
        0,
        0,
        0,
        0,
        0.8
      ],
      "speaking_speed": 1.0,
      "voice": "新云浩宇(影视模式).wav"
    },
    {
      "text": "往常我早就扑过去了",
      "role": "旁白",
