        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我却控制不住地在他怀里瑟瑟发抖",
