        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "四爷，西西以前不怕我的，今天也不让我抱",
