      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "夏辛在旁边碎碎念",
