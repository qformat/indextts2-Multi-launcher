{
  "roles": [
    {
      "name": "旁白",
      "description": "叙述者，负责故事叙述、动作环境描写",
      "suggested_voice": "逗阿生-解说beta.wav"
    },
    {
      "name": "战彦寒",
      "description": "我的原主人，性格冷硬多疑",
      "suggested_voice": "新云浩宇(影视模式).wav"
    }
  ],
  "segments": [
    {
      "text": "我本是一只无忧无虑的宠物猫",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "却因嘴馋偷喝了一口主人的可乐",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "没想竟从猫咪变成了人类",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "还好巧不巧被战彦寒撞正着",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "此时我裹着猫毯躺在床上",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "战彦寒以为我是对家派的诱饵",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "二话不说就掐住了我的脖子",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "他的眼神冷得像冰",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "你是怎么进来的",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "愤怒",
      "emotion_vector": [
        0,
        0.8,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.8
    },
    {
      "text": "我肚子上全是淤青",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "身上被划得鲜血淋漓",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "手心还在不停往外冒血",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "可战彦寒根本不吃这一套",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "认定我是为爬床演的苦肉计",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "他满眼嫌弃地开口询问",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "哑巴了",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "愤怒",
      "emotion_vector": [
        0,
        0.8,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.8
    },
    {
      "text": "那声音冷得我直打哆嗦",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "我惊恐地猛地一抬头",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "战彦寒整个人都僵住了",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "不是被我的美貌所惊艳",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "而是因为我祖母绿的眼睛",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "和他走丢的那只猫一模一样",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "但他眼底的寒意反而更重",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "谁派你来的",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "愤怒",
      "emotion_vector": [
        0,
        0.8,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.75
    },
    {
      "text": "由于缺氧我的脸涨得通红",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "眼角滑下一滴生理性的泪水",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "他才像丢垃圾甩我在地上",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "我疼得浑身发抖费劲爬起来",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "我不懂人类的羞耻观念",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "就光着身子拉开门往外走",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "战彦寒听到楼道的脚步声",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "烦躁地深深吸了一口气",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "冲过来一把将我拽了回去",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "随手从衣柜扯出一件衬衫",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "抬手就丢在了我的头上",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "我被砸得整个人都懵了",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "委屈得眼泪啪嗒直掉",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.3,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "喵呜",
      "role": "我",
      "type": "dialogue",
      "emotion": "恐惧",
      "emotion_vector": [
        0,
        0,
        0,
        0.7,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.2
    },
    {
      "text": "我本能求饶却发出猫叫声",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "战彦寒听了火气变得更大",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.0
    },
    {
      "text": "穿上衣服立马给我滚",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "愤怒",
      "emotion_vector": [
        0,
        0.8,
        0,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 0.7
    },
    {
      "text": "我抽噎着笨拙地穿衬衫",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.3,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.1
    },
    {
      "text": "慌慌张张把衬衫套反了",
      "role": "旁白",
      "type": "narration",
      "emotion": "哀",
      "emotion_vector": [
        0,
        0,
        0.3,
        0,
        0,
        0,
        0,
        0
      ],
      "speaking_speed": 1.1
    }
  ],
