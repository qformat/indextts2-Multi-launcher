{
  "block_id": "block_004",
  "segments": [
    {
      "text": "战彦寒坐在餐桌旁慢条斯理地吃着早餐",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1.0
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我趴在地上，愤愤不平地嚼着数十年如一日的猫粮",
      "role": "旁白",
      "type": "narration",
      "emotion": "愤愤不平",
      "emotion_vector": [
        0,
        0.4,
        0,
        0,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "幽怨地盯着餐桌旁的他",
      "role": "旁白",
      "type": "narration",
      "emotion": "幽怨",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.4,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "突然于思思跳了进来",
      "role": "旁白",
      "type": "narration",
      "emotion": "略带惊讶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0.3,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "四哥你看这个，笑死我了",
      "role": "旁白",
      "type": "dialogue",
      "emotion": "兴奋",
      "emotion_vector": [
        0.4,
        0,
        0,
        0,
        0,
        0,
        0.3,
        0.3
      ],
      "speaking_speed": 1.2,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "居然有人问吃什么能把猫变成女孩子",
      "role": "旁白",
      "type": "dialogue",
      "emotion": "兴奋",
      "emotion_vector": [
        0.4,
        0,
        0,
        0,
        0,
        0,
        0.3,
        0.3
      ],
      "speaking_speed": 1.2,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒一口豆浆直接喷了出来",
      "role": "旁白",
      "type": "narration",
      "emotion": "震惊",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0.4,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我眼睛一亮，盯上那杯豆浆",
      "role": "旁白",
      "type": "narration",
      "emotion": "期待",
      "emotion_vector": [
        0.3,
        0,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "那个抠门主人最爱喝的白白的东西",
      "role": "旁白",
      "type": "narration",
      "emotion": "期待",
      "emotion_vector": [
        0.3,
        0,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "今天总算让我逮到机会了",
      "role": "旁白",
      "type": "narration",
      "emotion": "急切",
      "emotion_vector": [
        0.4,
        0,
        0,
        0,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 1.1,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "滋溜一下，我窜到桌底疯狂舔食",
      "role": "旁白",
      "type": "narration",
      "emotion": "急切",
      "emotion_vector": [
        0.3,
        0,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.2,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "西西别喝脏！话还没说完",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "急切",
      "emotion_vector": [
        0,
        0.3,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.2,
      "voice": "云浩宇（影视模式.wav"
    },
    {
      "text": "我突然感觉身体一阵剧痛",
      "role": "旁白",
      "type": "narration",
      "emotion": "痛苦",
      "emotion_vector": [
        0,
        0,
        0.4,
        0,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "抓狂地捂着肚子冲上了二楼",
      "role": "旁白",
      "type": "narration",
      "emotion": "痛苦",
      "emotion_vector": [
        0,
        0.3,
        0.3,
        0,
        0,
        0,
        0,
        0.4
      ],
      "speaking_speed": 1.1,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒急匆匆推开二楼房门时",
      "role": "旁白",
      "type": "narration",
      "emotion": "担忧",
      "emotion_vector": [
        0,
        0,
        0.3,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我已经变成了一个不着寸缕的女孩",
      "role": "旁白",
      "type": "narration",
      "emotion": "震惊",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0.4,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "痛苦地在冰冷地板上挣扎",
      "role": "旁白",
      "type": "narration",
      "emotion": "痛苦",
      "emotion_vector": [
        0,
        0,
        0.4,
        0,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "他震惊地把我抱到柔软沙发上",
      "role": "旁白",
      "type": "narration",
      "emotion": "震惊",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0.4,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "你是西西对不对？快告诉我",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "急切",
      "emotion_vector": [
        0,
        0,
        0,
        0.3,
        0,
        0,
        0.3,
        0.4
      ],
      "speaking_speed": 1.1,
      "voice": "云浩宇（影视模式.wav"
    },
    {
      "text": "我茫然看着他，迟疑几秒后叫喵呜",
      "role": "旁白",
      "type": "dialogue",
      "emotion": "茫然",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.3,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "他笑了，我也跟着放松下来",
      "role": "旁白",
      "type": "narration",
      "emotion": "放松",
      "emotion_vector": [
        0.3,
        0,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "他温柔地把我紧紧按进怀里",
      "role": "旁白",
      "type": "narration",
      "emotion": "温柔",
      "emotion_vector": [
        0.3,
        0,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 0.9,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "突然，他像是意识到了什么",
      "role": "旁白",
      "type": "narration",
      "emotion": "惊讶",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0.3,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "他脸颊瞬间爆红，耳根都发烫",
      "role": "旁白",
      "type": "narration",
      "emotion": "害羞",
      "emotion_vector": [
        0.2,
        0,
        0,
        0.2,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "慌乱地从衣柜拽了件T恤扔给我",
      "role": "旁白",
      "type": "narration",
      "emotion": "慌乱",
      "emotion_vector": [
        0,
        0,
        0,
        0.3,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.2,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "快穿上这件宽松的T恤",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "急切",
      "emotion_vector": [
        0,
        0.3,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.2,
      "voice": "云浩宇（影视模式.wav"
    },
    {
      "text": "我委屈地摇着头不肯伸手",
      "role": "旁白",
      "type": "narration",
      "emotion": "委屈",
      "emotion_vector": [
        0,
        0,
        0.3,
        0,
        0,
        0.4,
        0,
        0.3
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我以前都不穿这种奇怪的东西",
      "role": "旁白",
      "type": "dialogue",
      "emotion": "委屈",
      "emotion_vector": [
        0,
        0,
        0.3,
        0,
        0,
        0.4,
        0,
        0.3
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "麻烦！赶紧给我穿上",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "恼火",
      "emotion_vector": [
        0,
        0.3,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.1,
      "voice": "云浩宇（影视模式.wav"
    },
    {
      "text": "说完直接胡乱套在我身上",
      "role": "旁白",
      "type": "narration",
      "emotion": "无奈",
      "emotion_vector": [
        0,
        0.2,
        0,
        0,
        0,
        0,
        0,
        0.8
      ],
      "speaking_speed": 1.1,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "我能不穿吗？这东西好奇怪",
      "role": "旁白",
      "type": "dialogue",
      "emotion": "疑惑",
      "emotion_vector": [
        0,
        0,
        0,
        0.3,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "不能！必须给我穿好",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "强硬",
      "emotion_vector": [
        0,
        0.4,
        0,
        0,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 1.2,
      "voice": "云浩宇（影视模式.wav"
    },
    {
      "text": "战彦寒皱着眉气得咬牙切齿",
      "role": "旁白",
      "type": "narration",
      "emotion": "恼火",
      "emotion_vector": [
        0,
        0.3,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "就在这时，房间的敲门声响起",
      "role": "旁白",
      "type": "narration",
      "emotion": "惊讶",
      "emotion_vector": [
        0,
        0,
        0,
        0.2,
        0,
        0,
        0,
        0.8
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "夏辛没等回应就推门而入",
      "role": "旁白",
      "type": "narration",
      "emotion": "惊讶",
      "emotion_vector": [
        0,
        0,
        0,
        0.2,
        0,
        0,
        0,
        0.8
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "卧槽！这妹子也太漂亮了吧",
      "role": "旁白",
      "type": "dialogue",
      "emotion": "震惊",
      "emotion_vector": [
        0,
        0,
        0,
        0.4,
        0,
        0,
        0.3,
        0.3
      ],
      "speaking_speed": 1.2,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "夏辛的眼珠子都快要瞪出来了",
      "role": "旁白",
      "type": "narration",
      "emotion": "震惊",
      "emotion_vector": [
        0,
        0,
        0,
        0.4,
        0,
        0,
        0.3,
        0.3
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒的房间连苍蝇都飞不进",
      "role": "旁白",
      "type": "narration",
      "emotion": "疑惑",
      "emotion_vector": [
        0,
        0,
        0,
        0.3,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "怎么会有女人穿着主子的衣服",
      "role": "旁白",
      "type": "dialogue",
      "emotion": "疑惑",
      "emotion_vector": [
        0,
        0,
        0,
        0.3,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒无情地狠狠甩上房门",
      "role": "旁白",
      "type": "narration",
      "emotion": "恼火",
      "emotion_vector": [
        0,
        0.3,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.1,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "差点撞断门外夏辛的鼻梁骨",
      "role": "旁白",
      "type": "narration",
      "emotion": "恼火",
      "emotion_vector": [
        0,
        0.2,
        0,
        0,
        0,
        0,
        0,
        0.8
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "他黑着脸给门外的人打电话",
      "role": "旁白",
      "type": "narration",
      "emotion": "恼火",
      "emotion_vector": [
        0,
        0.3,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "送这一季新款女装，内衣也要",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "强硬",
      "emotion_vector": [
        0,
        0.3,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.1,
      "voice": "云浩宇（影视模式.wav"
    },
    {
      "text": "挂了电话，他转头看向我",
      "role": "旁白",
      "type": "narration",
      "emotion": "恼火",
      "emotion_vector": [
        0,
        0.2,
        0,
        0,
        0,
        0,
        0,
        0.8
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "他看我露着大白腿越看越上火",
      "role": "旁白",
      "type": "narration",
      "emotion": "恼火",
      "emotion_vector": [
        0,
        0.3,
        0,
        0,
        0,
        0,
        0,
        0.7
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "转身又找了套宽松家居服递给我",
      "role": "旁白",
      "type": "narration",
      "emotion": "平静",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0,
        0,
        1.0
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "穿这个，这套更适合你",
      "role": "战彦寒",
      "type": "dialogue",
      "emotion": "无奈",
      "emotion_vector": [
        0,
        0.2,
        0,
        0,
        0,
        0,
        0,
        0.8
      ],
      "speaking_speed": 1.0,
      "voice": "云浩宇（影视模式.wav"
    },
    {
      "text": "我张开双臂，对着他撒娇卖萌",
      "role": "旁白",
      "type": "narration",
      "emotion": "撒娇",
      "emotion_vector": [
        0.4,
        0,
        0,
        0,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "主人，给我穿嘛~喵",
      "role": "旁白",
      "type": "dialogue",
      "emotion": "撒娇",
      "emotion_vector": [
        0.4,
        0,
        0,
        0,
        0,
        0,
        0,
        0.6
      ],
      "speaking_speed": 0.9,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "战彦寒一脸无奈，却没拒绝我",
      "role": "旁白",
      "type": "narration",
      "emotion": "无奈",
      "emotion_vector": [
        0,
        0,
        0,
        0,
        0,
        0.2,
        0,
        0.8
      ],
      "speaking_speed": 1.0,
      "voice": "故事-逗叔君.wav"
    },
    {
      "text": "只能红着脸笨拙地帮我穿好",
      "role": "旁白",
      "type": "narration",
      "emotion": "害羞",
      "emotion_vector": [
        0.3,
        0,
        0,
        0.2,
        0,
